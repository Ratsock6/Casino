generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  VIP
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum WalletTransactionType {
  ADMIN_CREDIT
  ADMIN_CREDIT_PAID
  ADMIN_DEBIT
  ADMIN_DEBIT_WITHDRAWAL
  BET
  WIN
  LOSS
  REFUND
  ADJUSTMENT
  WIN_JACKPOT
  WIN_LEVEL
  RAFFLE_TICKET
  WIN_RAFFLE
}

enum GameType {
  ROULETTE
  BLACKJACK
  SLOTS
  BATTLE_BOX
}

enum GameRoundStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum BlackjackGameStatus {
  PLAYER_TURN
  DEALER_TURN
  PLAYER_BUST
  DEALER_BUST
  PLAYER_BLACKJACK
  PLAYER_WIN
  DEALER_WIN
  PUSH
  FINISHED
}

model User {
  id               String     @id @default(cuid())
  username         String     @unique
  firstName        String
  lastName         String
  phoneNumber      String     @unique
  birthDate        DateTime
  passwordHash     String
  role             UserRole   @default(PLAYER)
  status           UserStatus @default(ACTIVE)
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  hasAcceptedTerms Boolean    @default(false)
  termsAcceptedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  loginHistory     LoginHistory[]
  jackpotWins      JackpotWin[]
  battleBoxPlayers BattleBoxPlayer[]
  discordId        String?   @unique
  discordUsername  String?
  metadata         Json?
  vipSubscriptions VipSubscription[]
  rewardCodeUses   RewardCodeUse[]
  playerLevel      PlayerLevel?
  raffleTickets    RaffleTicket[]

  wallet              Wallet?
  refreshTokens       RefreshToken[]
  transactions        WalletTransaction[]
  adminWalletActions  WalletTransaction[]  @relation("AdminWalletActions")
  adminActionsMade    AdminAction[]        @relation("AdminActionsMade")
  gameRounds          GameRound[]
  idempotencyRequests IdempotencyRequest[]
  blackjackGames      BlackjackGame[]

  @@index([username])
  @@index([role, status])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id            String                @id @default(cuid())
  userId        String
  type          WalletTransactionType
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  reason        String?
  gameType      String?
  gameRoundId   String?
  adminId       String?
  createdAt     DateTime              @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminWalletActions", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([gameType, gameRoundId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User? @relation("AdminActionsMade", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model GameRound {
  id         String          @id @default(cuid())
  userId     String
  gameType   GameType
  status     GameRoundStatus @default(PENDING)
  stake      BigInt
  payout     BigInt          @default(0)
  multiplier Float?
  metadata   Json?
  settledAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([gameType, status, createdAt])
}

model IdempotencyRequest {
  id           String            @id @default(cuid())
  key          String            @unique
  userId       String
  route        String
  requestHash  String
  status       IdempotencyStatus @default(PROCESSING)
  responseBody Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, route, createdAt])
}

model BlackjackGame {
  id          String              @id @default(cuid())
  gameRoundId String              @unique
  userId      String
  status      BlackjackGameStatus @default(PLAYER_TURN)
  betAmount   BigInt
  playerCards Json
  dealerCards Json
  playerScore Int
  dealerScore Int
  playerSoft  Boolean             @default(false)
  dealerSoft  Boolean             @default(false)
  canDouble   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}


model CasinoConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VipSubscription {
  id        String    @id @default(cuid())
  userId    String
  startedAt DateTime  @default(now())
  expiresAt DateTime?  // null = à vie
  duration  String    // '1_MONTH', '3_MONTHS', '6_MONTHS', 'LIFETIME'
  price     Int
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlayerLevel {
  id           String   @id @default(cuid())
  userId       String   @unique
  level        Int      @default(1)
  currentXp    BigInt   @default(0)
  totalXp      BigInt   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards      LevelReward[]

  @@index([userId])
  @@index([level])
}

model LevelReward {
  id              String    @id @default(cuid())
  userId          String
  level           Int
  rewardType      String    // 'TOKENS', 'VIP', 'BADGE', 'INGAME'
  rewardValue     String
  isIngame        Boolean   @default(false)
  ingameValue     Int?      // valeur estimée en jetons du lot RP (compta informative)
  ingameClaimed   Boolean   @default(false)
  ingameClaimedAt DateTime?
  ingameClaimedBy String?   // adminId qui a validé
  claimed         Boolean   @default(false)
  claimedAt       DateTime  @default(now())

  playerLevel     PlayerLevel @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, level])
  @@index([isIngame, ingameClaimed])
}

model Jackpot {
  id          String    @id @default(cuid())
  amount      BigInt    @default(0)
  isActive    Boolean   @default(true)
  lastWonAt   DateTime?
  lastWonBy   String?
  lastWonAmount BigInt?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model JackpotWin {
  id        String   @id @default(cuid())
  userId    String
  amount    BigInt
  gameType  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum BattleBoxStatus {
  WAITING
  READY
  PLAYING
  FINISHED
  CANCELLED
}

model BattleBoxGame {
  id           String            @id @default(cuid())
  status       BattleBoxStatus   @default(WAITING)
  maxPlayers   Int               @default(2)
  teamSize     Int               @default(1)
  isPrivate    Boolean           @default(false)
  inviteCode   String?           @unique
  boxTypes     Json              // { STANDARD: 2, PREMIUM: 1 } etc...
  totalStake   BigInt            @default(0)
  commissionPct Float            @default(5)
  winnerId     String?
  winnerTeam   Int?
  createdAt    DateTime          @default(now())
  startedAt    DateTime?
  settledAt    DateTime?

  players      BattleBoxPlayer[]

  @@index([status, isPrivate])
  @@index([inviteCode])
}

model BattleBoxPlayer {
  id          String        @id @default(cuid())
  gameId      String
  userId      String
  teamIndex   Int           @default(0)
  stake       BigInt
  items       Json?         // objets obtenus après ouverture
  totalValue  BigInt?       // valeur totale des objets
  isWinner    Boolean       @default(false)
  joinedAt    DateTime      @default(now())

  game        BattleBoxGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model RewardCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  rewardType    String    // 'TOKENS', 'VIP', 'BADGE', 'IRL'
  rewardValue   String    // montant, durée VIP, nom badge, description IRL
  maxUses       Int?      // null = illimité
  currentUses   Int       @default(0)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdBy     String
  createdAt     DateTime  @default(now())

  uses          RewardCodeUse[]

  @@index([code])
  @@index([isActive])
}

model RewardCodeUse {
  id        String   @id @default(cuid())
  codeId    String
  userId    String
  usedAt    DateTime @default(now())

  code      RewardCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TOMBOLA / RAFFLE
// ─────────────────────────────────────────────────────────────────────────────

enum RaffleCampaignStatus {
  DRAFT // créée, configurée, pas encore ouverte aux achats
  OPEN  // achats de tickets autorisés
  ENDED // campagne terminée (dernier tirage passé)
}

enum RaffleDrawStatus {
  PENDING // tirage programmé, pas encore exécuté
  DONE    // tirage exécuté, gagnants désignés
}

enum RafflePrizeType {
  CHIPS  // jetons (montant dans `value`)
  VIP    // abonnement VIP (durée dans `value`, remis en RP par le staff)
  CUSTOM // objet RP / lot physique (description dans `label`)
}

enum RaffleTicketStatus {
  ACTIVE // en lice pour les prochains tirages
  WON    // a gagné -> retiré du pool
}

enum RaffleClaimStatus {
  UNCLAIMED // ticket gagnant, en attente que le joueur ouvre sa réclamation
  CLAIMED   // lot réclamé/remis par le staff
  EXPIRED   // délai de réclamation dépassé -> lot perdu
}

/// Une campagne de tombola (ex : "Tombola de lancement", 2 semaines).
/// En principe une seule en statut OPEN à la fois.
model RaffleCampaign {
  id                String               @id @default(cuid())
  name              String
  description       String?
  status            RaffleCampaignStatus @default(DRAFT)
  ticketPrice       BigInt // prix d'un ticket en jetons
  maxTicketsPerUser Int // plafond global sur toute la campagne
  startsAt          DateTime // ouverture des achats
  endsAt            DateTime // fin de campagne (après le dernier tirage)
  createdBy         String // userId admin créateur
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  draws   RaffleDraw[]
  tickets RaffleTicket[]

  @@index([status])
  @@index([startsAt, endsAt])
}

/// Un tirage programmé au sein d'une campagne (un tous les 2 jours, ~7 au total).
model RaffleDraw {
  id          String           @id @default(cuid())
  campaignId  String
  label       String? // ex : "Tirage #3"
  scheduledAt DateTime // date/heure prévue du tirage
  status      RaffleDrawStatus @default(PENDING)
  executedAt  DateTime? // rempli quand le tirage est exécuté
  seed        String? // graine RNG conservée pour l'audit
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  campaign   RaffleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prizes     RafflePrize[]
  wonTickets RaffleTicket[] @relation("RaffleTicketWonDraw")

  @@index([campaignId])
  @@index([status, scheduledAt])
}

/// Un lot rattaché à un tirage précis (lots fixes définis à l'avance).
/// `quantity` = nombre de gagnants pour ce lot lors du tirage.
model RafflePrize {
  id        String          @id @default(cuid())
  drawId    String
  type      RafflePrizeType
  label     String // "1 000 000 jetons", "VIP 1 mois", "Plaque collector"
  value     String? // montant (jetons) ou durée VIP ('1_MONTH'...) ; null pour CUSTOM
  rank      Int             @default(1) // ordre d'affichage / prestige (1 = lot principal)
  quantity  Int             @default(1) // nombre de gagnants pour ce lot
  createdAt DateTime        @default(now())

  draw       RaffleDraw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  wonTickets RaffleTicket[] @relation("RaffleTicketWonPrize")

  @@index([drawId])
}

/// Un ticket acheté par un joueur. Cumulatif et permanent jusqu'à victoire.
model RaffleTicket {
  id           String             @id @default(cuid())
  campaignId   String
  userId       String
  ticketNumber Int // numéro séquentiel dans la campagne
  status       RaffleTicketStatus @default(ACTIVE)
  purchasedAt  DateTime           @default(now())

  // Renseignés uniquement si le ticket a gagné
  wonDrawId     String?
  wonPrizeId    String?
  claimStatus   RaffleClaimStatus? // null tant que ACTIVE ; UNCLAIMED dès qu'il gagne
  claimDeadline DateTime? // délai pour ouvrir la réclamation (tirage + 3 jours)
  claimedAt     DateTime?

  campaign RaffleCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wonDraw  RaffleDraw?    @relation("RaffleTicketWonDraw", fields: [wonDrawId], references: [id], onDelete: SetNull)
  wonPrize RafflePrize?   @relation("RaffleTicketWonPrize", fields: [wonPrizeId], references: [id], onDelete: SetNull)

  @@unique([campaignId, ticketNumber])
  @@index([campaignId, status])
  @@index([userId, campaignId])
  @@index([wonDrawId])
  @@index([claimStatus, claimDeadline])
}
