generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  VIP
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

enum WalletTransactionType {
  ADMIN_CREDIT
  ADMIN_DEBIT
  BET
  WIN
  LOSS
  REFUND
  ADJUSTMENT
  WIN_JACKPOT
  WIN_LEVEL
}

enum GameType {
  ROULETTE
  BLACKJACK
  SLOTS
}

enum GameRoundStatus {
  PENDING
  WON
  LOST
  REFUNDED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum BlackjackGameStatus {
  PLAYER_TURN
  DEALER_TURN
  PLAYER_BUST
  DEALER_BUST
  PLAYER_BLACKJACK
  PLAYER_WIN
  DEALER_WIN
  PUSH
  FINISHED
}

model User {
  id               String     @id @default(cuid())
  username         String     @unique
  firstName        String
  lastName         String
  phoneNumber      String     @unique
  birthDate        DateTime
  passwordHash     String
  role             UserRole   @default(PLAYER)
  status           UserStatus @default(ACTIVE)
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  hasAcceptedTerms Boolean    @default(false)
  termsAcceptedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  loginHistory     LoginHistory[]
  jackpotWins      JackpotWin[]
  discordId        String?   @unique
  discordUsername  String?
  metadata         Json?
  vipSubscriptions VipSubscription[]
  playerLevel      PlayerLevel?

  wallet              Wallet?
  refreshTokens       RefreshToken[]
  transactions        WalletTransaction[]
  adminWalletActions  WalletTransaction[]  @relation("AdminWalletActions")
  adminActionsMade    AdminAction[]        @relation("AdminActionsMade")
  gameRounds          GameRound[]
  idempotencyRequests IdempotencyRequest[]
  blackjackGames      BlackjackGame[]

  @@index([username])
  @@index([role, status])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id            String                @id @default(cuid())
  userId        String
  type          WalletTransactionType
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  reason        String?
  gameType      String?
  gameRoundId   String?
  adminId       String?
  createdAt     DateTime              @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("AdminWalletActions", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([gameType, gameRoundId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User? @relation("AdminActionsMade", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model GameRound {
  id         String          @id @default(cuid())
  userId     String
  gameType   GameType
  status     GameRoundStatus @default(PENDING)
  stake      BigInt
  payout     BigInt          @default(0)
  multiplier Float?
  metadata   Json?
  settledAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([gameType, status, createdAt])
}

model IdempotencyRequest {
  id           String            @id @default(cuid())
  key          String            @unique
  userId       String
  route        String
  requestHash  String
  status       IdempotencyStatus @default(PROCESSING)
  responseBody Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, route, createdAt])
}

model BlackjackGame {
  id          String              @id @default(cuid())
  gameRoundId String              @unique
  userId      String
  status      BlackjackGameStatus @default(PLAYER_TURN)
  betAmount   BigInt
  playerCards Json
  dealerCards Json
  playerScore Int
  dealerScore Int
  playerSoft  Boolean             @default(false)
  dealerSoft  Boolean             @default(false)
  canDouble   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}


model CasinoConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([key])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VipSubscription {
  id        String    @id @default(cuid())
  userId    String
  startedAt DateTime  @default(now())
  expiresAt DateTime?  // null = à vie
  duration  String    // '1_MONTH', '3_MONTHS', '6_MONTHS', 'LIFETIME'
  price     Int
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlayerLevel {
  id           String   @id @default(cuid())
  userId       String   @unique
  level        Int      @default(1)
  currentXp    BigInt   @default(0)
  totalXp      BigInt   @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards      LevelReward[]

  @@index([userId])
  @@index([level])
}

model LevelReward {
  id              String    @id @default(cuid())
  userId          String
  level           Int
  rewardType      String    // 'TOKENS', 'VIP', 'BADGE', 'INGAME'
  rewardValue     String
  isIngame        Boolean   @default(false)
  ingameClaimed   Boolean   @default(false)
  ingameClaimedAt DateTime?
  ingameClaimedBy String?   // adminId qui a validé
  claimed         Boolean   @default(false)
  claimedAt       DateTime  @default(now())

  playerLevel     PlayerLevel @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, level])
  @@index([isIngame, ingameClaimed])
}

model Jackpot {
  id          String    @id @default(cuid())
  amount      BigInt    @default(0)
  isActive    Boolean   @default(true)
  lastWonAt   DateTime?
  lastWonBy   String?
  lastWonAmount BigInt?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model JackpotWin {
  id        String   @id @default(cuid())
  userId    String
  amount    BigInt
  gameType  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
